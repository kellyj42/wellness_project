# Sanity Configuration
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
# Get your API token from: https://www.sanity.io/manage/personal/tokens
SANITY_API_TOKEN=your_sanity_api_token_here

# Studio Authentication - Protect /sanity route from public access
# Generate a strong random token and keep it secret
# Access: http://localhost:3000/sanity?token=your_token_here
STUDIO_AUTH_TOKEN=your_strong_random_token_here

# Google Places API Configuration
# Get your API key from: https://console.cloud.google.com/apis/credentials
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Your Google Business Place ID
# Find it here: https://developers.google.com/maps/documentation/places/web-service/place-id
GOOGLE_PLACE_ID=your_google_place_id_here
